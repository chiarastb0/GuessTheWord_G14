                        </Label>
                        <TextField fx:id="txtLoginUser" promptText="Inserisci username" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" />
