                  <Button maxWidth="1.0E308" mnemonicParsing="false" onAction="#gestisciRegistrazione" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10;" text="Conferma Registrazione">
