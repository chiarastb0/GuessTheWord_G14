                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <PasswordField fx:id="txtLoginPass" promptText="Inserisci password" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" />
                     </children>
                     <VBox.margin>
                        <Insets left="24.0" right="24.0" />
