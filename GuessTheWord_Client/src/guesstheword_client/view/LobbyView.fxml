<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<TabPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #E3F2FD; -fx-tab-header-background: transparent;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="guesstheword_client.controller.LobbyController">
   <tabs>
      <Tab closable="false" style="-fx-background-color: white; -fx-text-base-color: #1a4261; -fx-background-radius: 10 10 0 0; -fx-border-radius: 10 10 0 0; -fx-border-color: #CBD5E1; -fx-border-width: 1 1 0 1; -fx-font-weight: bold;" text="Lobby di Attesa">
         <content>
            <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="540.0" prefWidth="800.0">
               <children>
                  <VBox alignment="CENTER" spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-padding: 40;" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="50.0">
                     <children>
                        <Label fx:id="lblBenvenuto" text="👋 Benvenuto nella Lobby!" textFill="#1E3A8A">
                           <font>
                              <Font name="System Bold" size="28.0" />
                           </font>
                        </Label>
                        <Label fx:id="lblStatoLobby" text="Clicca sul bottone sottostante per metterti in coda e cercare una sfida." textAlignment="CENTER" textFill="#475569" wrapText="true">
                           <font>
                              <Font size="16.0" />
                           </font>
                        </Label>
                        <Button fx:id="btnAvviaSfida" mnemonicParsing="false" onAction="#gestisciAvviaSfida" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 30 12 30; -fx-cursor: hand;" text="🚀 TROVA UNA SFIDA">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </content>
      </Tab>

      <Tab closable="false" style="-fx-background-color: #DBEAFE; -fx-text-base-color: #64748B; -fx-background-radius: 10 10 0 0; -fx-border-radius: 10 10 0 0; -fx-border-color: #CBD5E1; -fx-border-width: 1 1 1 1; -fx-font-weight: bold;" text="Storico Partite">
         <content>
            <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="540.0" prefWidth="800.0">
               <children>
                  <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
                     <children>
                        <Label alignment="CENTER" prefHeight="40.0" text="Le tue ultime sfide" textFill="#1a4261">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>
                        <TableView fx:id="tabellaStorico" prefHeight="380.0" prefWidth="720.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1;" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colData" prefWidth="180.0" style="-fx-background-color: #F8FAFC; -fx-font-weight: bold;" text="Data" />
                              <TableColumn fx:id="colParola" prefWidth="180.0" style="-fx-background-color: #F8FAFC; -fx-font-weight: bold;" text="Parola" />
                              <TableColumn fx:id="colEsito" prefWidth="180.0" style="-fx-background-color: #F8FAFC; -fx-font-weight: bold;" text="Esito" />
                              <TableColumn fx:id="colPunteggio" prefWidth="178.0" style="-fx-background-color: #F8FAFC; -fx-font-weight: bold;" text="Punteggio" />
                           </columns>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </content>
      </Tab>

      <Tab closable="false" style="-fx-background-color: #D1FAE5; -fx-text-base-color: #065F46; -fx-background-radius: 10 10 0 0; -fx-border-radius: 10 10 0 0; -fx-border-color: #CBD5E1; -fx-border-width: 1 1 1 1; -fx-font-weight: bold;" text="Classifiche">
         <content>
            <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="540.0" prefWidth="800.0">
               <children>
                  <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
                     <children>
                        <Label alignment="CENTER" prefHeight="40.0" text="🏆 Classifica Globale Giocatori" textFill="#10B981">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>
                        <TableView fx:id="tabellaClassifica" prefHeight="380.0" prefWidth="720.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1;" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colPosizione" prefWidth="150.0" style="-fx-background-color: #F0FDF4; -fx-font-weight: bold; -fx-alignment: CENTER;" text="Posizione" />
                              <TableColumn fx:id="colUtente" prefWidth="370.0" style="-fx-background-color: #F0FDF4; -fx-font-weight: bold;" text="Nome Utente" />
                              <TableColumn fx:id="colPuntiTotali" prefWidth="198.0" style="-fx-background-color: #F0FDF4; -fx-font-weight: bold; -fx-alignment: CENTER;" text="Punti Totali" />
                           </columns>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </content>
      </Tab>
   </tabs>
</TabPane>